    "@prisma/client": "^7.6.0",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.5.6",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.0",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "qs": "^6.15.1",
    "stripe": "^22.0.2",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
